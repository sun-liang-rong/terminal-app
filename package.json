{
  "name": "terminal-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-vite": "^5.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.0",
    "node-pty": "^1.1.0",
    "ssh2": "^1.17.0",
    "vue": "^3.5.30",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "svg-to-ico": "^1.1.1",
    "typescript": "^6.0.2",
    "vite": "^7.0.1",
    "vue-tsc": "^3.2.6",
    "wait-on": "^9.0.4"
  },
  "build": {
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "appId": "com.terminal.app",
    "productName": "Terminal MVP",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/node-pty",
        "to": "app/node_modules/node-pty",
        "filter": [
          "build/**/*",
          "lib/**/*",
          "package.json",
          "*.js"
        ]
      },
      {
        "from": "node_modules/ssh2",
        "to": "app/node_modules/ssh2",
        "filter": [
          "lib/**/*",
          "package.json",
          "*.js"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/build/**/*.node",
      "node_modules/ssh2/build/**/*.node"
    ],
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "win": {
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Terminal MVP"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Development"
    }
  }
}
